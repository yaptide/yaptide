# Environment variables for the local SLURM development setup.
#
# Usage — two options:
#
# Option A: copy to .env in the yaptide root before running compose
#   cp local-dev/.env.local-slurm .env
#   docker compose -f local-dev/docker-compose-local-slurm.yml up --build
#
# Option B: pass directly to compose (variable substitution only, not injected)
#   docker compose -f local-dev/docker-compose-local-slurm.yml \
#                  --env-file local-dev/.env.local-slurm up --build
#
# The important backend URLs are hardcoded directly in docker-compose-local-slurm.yml
# so the stack works out-of-the-box without needing to set these.
# The variables below are mainly documentation and defaults for the base docker-compose.yml.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=yaptide_db
POSTGRES_USER=yaptide_user
POSTGRES_PASSWORD=yaptide_password

# ── Backend service URLs (used inside Docker network) ─────────────────────────
# These override the empty defaults from docker-compose.yml.
CERT_AUTH_URL=http://cert-issuer:8000/key
KEYCLOAK_BASE_URL=http://keycloak:8080
KEYCLOAK_REALM=yaptide-local
BACKEND_EXTERNAL_URL=http://nginx:5000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL_ROOT=DEBUG

# ── React UI env vars (set these when running the UI dev server) ──────────────
# REACT_APP_BACKEND_URL=http://localhost:5000
# REACT_APP_KEYCLOAK_BASE_URL=http://localhost:8080
# REACT_APP_KEYCLOAK_REALM=yaptide-local
# REACT_APP_KEYCLOAK_CLIENT_ID=yaptide-client
# REACT_APP_ALT_AUTH=plg
